// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String
  telefono  String?
  reservas  Reserva[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Barbero {
  id             Int       @id @default(autoincrement())
  nombre         String
  horarioLaboral String?   // Ej: "09:00 - 18:00"
  imagen         String?   // URL de la foto de perfil
  reservas       Reserva[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Servicio {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float     // Precio en moneda local
  duracion    Int       // Duración en minutos
  imagen      String?   // URL representativa del corte
  reservas    Reserva[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reserva {
  id         Int      @id @default(autoincrement())
  fechaHora  DateTime
  estado     String   @default("PENDIENTE") // Opciones: PENDIENTE, CONFIRMADA, CANCELADA, COMPLETADA
  
  // Relaciones
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  barberoId  Int
  barbero    Barbero  @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  categoria String   // Ej: "Pomadas", "Cremas", "Geles", "Navajas"
  precio    Float    // Precio de venta
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaccion {
  id          Int      @id @default(autoincrement())
  fecha       DateTime
  descripcion String
  categoria   String   // Ej: "Servicios", "Inventario", "Alquiler", "Servicios Básicos"
  tipo        String   // "INGRESO" o "GASTO"
  monto       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
